PORT=3000
STELLAR_NETWORK=testnet
STELLAR_SERVER_SECRET_KEY=<generate with: npm run keygen>
STELLAR_SERVER_PUBLIC_KEY=<public key from keygen output>
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
GROQ_API_KEY=gsk_...   # free at console.groq.com
MPP_ENABLED=false

# Optional: testnet USDC distributor for the agent demo
# A Stellar testnet account that holds USDC and can send it to the agent
TESTNET_USDC_DISTRIBUTOR_SECRET=<optional, for agent demo auto-funding>

# Agent demo target server
SERVER_URL=http://localhost:3000
