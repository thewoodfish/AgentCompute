PORT=3000
STELLAR_NETWORK=testnet
STELLAR_SERVER_SECRET_KEY=<generate with: npm run keygen>
STELLAR_SERVER_PUBLIC_KEY=<public key from keygen output>
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
SOROBAN_RPC_URL=https://soroban-testnet.stellar.org

# LLM jobs (summarize, classify, analyze)
ANTHROPIC_API_KEY=<get at console.anthropic.com>
GROQ_API_KEY=<get a free key at console.groq.com>

# MPP channel mode — requires deployed one-way-channel Soroban contract
# See: https://github.com/stellar-experimental/one-way-channel
MPP_ENABLED=false
CHANNEL_CONTRACT=<deployed contract address>

# Keypair used by the channel demo agent (must have funded testnet USDC balance)
CHANNEL_DEMO_SECRET=<generate with: npm run keygen>
CHANNEL_DEMO_PUBLIC=<public key from keygen output>

# Optional: testnet USDC distributor for the agent demo
TESTNET_USDC_DISTRIBUTOR_SECRET=<optional, for agent demo auto-funding>

# Agent demo target server
SERVER_URL=http://localhost:3000
